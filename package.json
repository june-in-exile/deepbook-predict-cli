{
  "name": "deepbook-predict-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Toy CLI + slides for learning the DeepBook Predict protocol on Sui testnet.",
  "bin": {
    "deepbook-predict": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "license": "MIT",
  "author": "Chen Chi June <df41022@gmail.com>",
  "keywords": [
    "sui",
    "deepbook",
    "predict",
    "options",
    "cli",
    "testnet"
  ],
  "scripts": {
    "setup": "tsx src/scripts/setup.ts",
    "inspect": "tsx src/scripts/inspect.ts",
    "markets": "tsx src/scripts/markets.ts",
    "deposit": "tsx src/scripts/deposit.ts",
    "withdraw": "tsx src/scripts/withdraw.ts",
    "mint-binary": "tsx src/scripts/mint-binary.ts",
    "mint-range": "tsx src/scripts/mint-range.ts",
    "preview": "tsx src/scripts/preview.ts",
    "redeem": "tsx src/scripts/redeem.ts",
    "redeem-range": "tsx src/scripts/redeem-range.ts",
    "lp-supply": "tsx src/scripts/lp-supply.ts",
    "lp-withdraw": "tsx src/scripts/lp-withdraw.ts",
    "e2e": "tsx src/scripts/e2e.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@mysten/sui": "^1.21.2",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
